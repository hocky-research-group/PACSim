Cell["Vacuum permittivity in J/(mV^2 nm).", "Text",
 CellChangeTimes->{{3.9199422645330133`*^9, 
  3.919942267909066*^9}},ExpressionUUID->"28304cd3-9094-42d7-97ee-\
d7c0fcb4830b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Epsilon]0", "=", 
   RowBox[{"\[Epsilon]0Si", "*", 
    FractionBox["1", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        SuperscriptBox["10", "3"], ")"}], "2"], "*", 
      SuperscriptBox["10", "9"]}]]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.919942270750801*^9, 3.919942310134777*^9}},
 CellLabel->"In[4]:=",ExpressionUUID->"8acd1c1a-e644-4bbf-b122-ea04afc98385"],

Cell["Conversion factor from J to kJ/mol.", "Text",
 CellChangeTimes->{{3.919942093605631*^9, 
  3.919942100506465*^9}},ExpressionUUID->"2fc467c0-58cf-4ba0-b9db-\
c4c66c68c1dd"],

Cell[BoxData[
 RowBox[{
  RowBox[{"convJTokJPerMole", "=", 
   FractionBox["avogadrosNumber", 
    SuperscriptBox["10", "3"]]}], ";"}]], "Input",
 CellChangeTimes->{{3.919941943009767*^9, 3.919941971881259*^9}, {
  3.919942032656269*^9, 3.919942042877685*^9}},
 CellLabel->"In[5]:=",ExpressionUUID->"6a7a68d7-2a28-44a7-8be0-94a034d55967"],

Cell["Steric potential in kJ/mol.", "Text",
 CellChangeTimes->{{3.9199419025299377`*^9, 3.919941930257957*^9}, {
  3.919942061439685*^9, 3.919942064681241*^9}, {3.919942330717462*^9, 
  3.919942332721807*^9}},ExpressionUUID->"85ad2e07-2a8d-4a7c-a1b6-\
54183de5c9bb"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"repPot", "[", 
    RowBox[{
    "h_", ",", "r1_", ",", "r2_", ",", "l_", ",", "\[Sigma]_", ",", "t_"}], 
    "]"}], ":=", 
   RowBox[{
    RowBox[{"HeavisideTheta", "[", 
     RowBox[{
      RowBox[{"2", "*", "l"}], "-", "h"}], "]"}], "*", "kb", "*", "t", "*", 
    FractionBox[
     RowBox[{"16", "*", "\[Pi]", "*", 
      RowBox[{"(", 
       FractionBox[
        RowBox[{"r1", "+", "r2"}], "2"], ")"}], "*", 
      SuperscriptBox["l", "2"], "*", 
      SuperscriptBox["\[Sigma]", 
       RowBox[{"3", "/", "2"}]]}], "35"], "*", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"28", "*", 
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox[
          RowBox[{"(", 
           FractionBox[
            RowBox[{"2", "*", "l"}], "h"], ")"}], 
          RowBox[{"1", "/", "4"}]], "-", "1"}], ")"}]}], "+", 
      RowBox[{
       FractionBox["20", "11"], "*", 
       RowBox[{"(", 
        RowBox[{"1", "-", 
         SuperscriptBox[
          RowBox[{"(", 
           FractionBox["h", 
            RowBox[{"2", "*", "l"}]], ")"}], 
          RowBox[{"11", "/", "4"}]]}], ")"}]}], "+", 
      RowBox[{"12", "*", 
       RowBox[{"(", 
        RowBox[{
         FractionBox["h", 
          RowBox[{"2", "*", "l"}]], "-", "1"}], ")"}]}]}], ")"}], "*", 
    "convJTokJPerMole"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9199414249288235`*^9, 3.919941469853604*^9}, 
   3.919941515928504*^9, {3.919941559510392*^9, 3.919941669056561*^9}, {
   3.9199419380684347`*^9, 3.919941938891356*^9}, {3.919942051022415*^9, 
   3.919942058212077*^9}, {3.919943994318742*^9, 3.919944009179566*^9}},
 CellLabel->"In[6]:=",ExpressionUUID->"7cfb75dc-8405-44d0-a5cf-eca6149a1bb9"],

Cell["Electrostatic potential in kJ/mol.", "Text",
 CellChangeTimes->{{3.91994234407342*^9, 
  3.919942351805936*^9}},ExpressionUUID->"dea55d39-ed0d-4749-9376-\
8914c7cf3ccb"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"attPot", "[", 
    RowBox[{
    "h_", ",", "r1_", ",", "r2_", ",", "psi1_", ",", "psi2_", ",", "ld_", ",",
      "\[Epsilon]_"}], "]"}], ":=", 
   RowBox[{
   "2", "*", "\[Pi]", "*", "\[Epsilon]", "*", "\[Epsilon]0", "*", "psi1", "*",
     "psi2", "*", 
    RowBox[{"(", 
     FractionBox["2", 
      RowBox[{
       FractionBox["1", "r1"], "+", 
       FractionBox["1", "r2"]}]], ")"}], "*", 
    RowBox[{"Exp", "[", 
     RowBox[{"-", 
      FractionBox["h", "ld"]}], "]"}], "*", "convJTokJPerMole"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.919941697227987*^9, 3.9199418106884947`*^9}, {
  3.919942356519916*^9, 3.919942405814177*^9}, {3.920472852560843*^9, 
  3.920472865227703*^9}, {3.9204730571890182`*^9, 3.9204730576618834`*^9}},
 CellLabel->"In[20]:=",ExpressionUUID->"0a9c5177-a6b1-47d1-bc8a-11ba353e4acb"],

Cell["Electrostatic potential with logarithm in kJ/mol.", "Text",
 CellChangeTimes->{{3.91996587094289*^9, 
  3.919965881536264*^9}},ExpressionUUID->"104e34e4-c539-4224-b457-\
41d4c12f4463"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"attPotLog", "[", 
    RowBox[{
    "h_", ",", "r1_", ",", "r2_", ",", "psi1_", ",", "psi2_", ",", "ld_", ",",
      "\[Epsilon]_"}], "]"}], ":=", 
   RowBox[{
   "2", "*", "\[Pi]", "*", "\[Epsilon]", "*", "\[Epsilon]0", "*", "psi1", "*",
     "psi2", "*", 
    RowBox[{"(", 
     FractionBox["2", 
      RowBox[{
       FractionBox["1", "r1"], "+", 
       FractionBox["1", "r2"]}]], ")"}], "*", 
    RowBox[{"Log", "[", 
     RowBox[{"1", "+", 
      RowBox[{"Exp", "[", 
       RowBox[{"-", 
        FractionBox["h", "ld"]}], "]"}]}], "]"}], "*", "convJTokJPerMole"}]}],
   ";"}]], "Input",
 CellChangeTimes->{{3.91996589020654*^9, 3.919965912859661*^9}, 
   3.92047287172184*^9, {3.920473063122984*^9, 3.920473063487521*^9}},
 CellLabel->"In[21]:=",ExpressionUUID->"b208ca0d-e209-4852-8219-bf371e68b016"],

