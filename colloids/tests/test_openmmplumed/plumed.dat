# Calculate the Steinhardt Q6 vector for each of the atoms in the system
q6: Q6 SPECIES=1-256 SWITCH={GAUSSIAN R_0=50.0 D_0=200.0} NOPBC MEAN
PRINT ARG=q6.mean FILE=colvar STRIDE=10000
DUMPMULTICOLVAR DATA=q6 FILE=Q6MULTICOLVAR.xyz STRIDE=10000
