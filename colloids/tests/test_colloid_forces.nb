   FractionBox["avogadrosNumber", 
    SuperscriptBox["10", "3"]]}], ";"}]], "Input",
 CellChangeTimes->{{3.919941943009767*^9, 3.919941971881259*^9}, {
  3.919942032656269*^9, 3.919942042877685*^9}},
 CellLabel->"In[5]:=",ExpressionUUID->"6a7a68d7-2a28-44a7-8be0-94a034d55967"],

Cell["Steric potential in kJ/mol.", "Text",
 CellChangeTimes->{{3.9199419025299377`*^9, 3.919941930257957*^9}, {
  3.919942061439685*^9, 3.919942064681241*^9}, {3.919942330717462*^9, 
  3.919942332721807*^9}},ExpressionUUID->"85ad2e07-2a8d-4a7c-a1b6-\
54183de5c9bb"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"repPot", "[", 
    RowBox[{
    "h_", ",", "r1_", ",", "r2_", ",", "l_", ",", "\[Sigma]_", ",", "t_"}], 
    "]"}], ":=", 
   RowBox[{
    RowBox[{"HeavisideTheta", "[", 
     RowBox[{
      RowBox[{"2", "*", "l"}], "-", "h"}], "]"}], "*", "kb", "*", "t", "*", 
    FractionBox[
     RowBox[{"16", "*", "\[Pi]", "*", 
      RowBox[{"(", 
       FractionBox[
        RowBox[{"r1", "+", "r2"}], "2"], ")"}], "*", 
      SuperscriptBox["l", "2"], "*", 
      SuperscriptBox["\[Sigma]", 
       RowBox[{"3", "/", "2"}]]}], "35"], "*", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"28", "*", 
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox[
          RowBox[{"(", 
           FractionBox[
            RowBox[{"2", "*", "l"}], "h"], ")"}], 
          RowBox[{"1", "/", "4"}]], "-", "1"}], ")"}]}], "+", 
      RowBox[{
       FractionBox["20", "11"], "*", 
       RowBox[{"(", 
        RowBox[{"1", "-", 
         SuperscriptBox[
          RowBox[{"(", 
           FractionBox["h", 
            RowBox[{"2", "*", "l"}]], ")"}], 
          RowBox[{"11", "/", "4"}]]}], ")"}]}], "+", 
      RowBox[{"12", "*", 
       RowBox[{"(", 
        RowBox[{
         FractionBox["h", 
          RowBox[{"2", "*", "l"}]], "-", "1"}], ")"}]}]}], ")"}], "*", 
    "convJTokJPerMole"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9199414249288254`*^9, 3.919941469853604*^9}, 
   3.919941515928504*^9, {3.919941559510392*^9, 3.919941669056561*^9}, {
   3.9199419380684347`*^9, 3.919941938891356*^9}, {3.919942051022415*^9, 
   3.919942058212077*^9}, {3.9199439943187437`*^9, 3.919944009179566*^9}},
 CellLabel->"In[6]:=",ExpressionUUID->"7cfb75dc-8405-44d0-a5cf-eca6149a1bb9"],

Cell["Electrostatic potential in kJ/mol.", "Text",
 CellChangeTimes->{{3.91994234407342*^9, 
  3.919942351805936*^9}},ExpressionUUID->"dea55d39-ed0d-4749-9376-\
8914c7cf3ccb"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"attPot", "[", 
    RowBox[{
    "h_", ",", "r1_", ",", "r2_", ",", "psi1_", ",", "psi2_", ",", "ld_", ",",
      "\[Epsilon]_"}], "]"}], ":=", 
   RowBox[{
   "2", "*", "\[Pi]", "*", "\[Epsilon]", "*", "\[Epsilon]0", "*", "psi1", "*",
     "psi2", "*", 
    RowBox[{"(", 
     FractionBox["2", 
      RowBox[{
       FractionBox["1", "r1"], "+", 
       FractionBox["1", "r2"]}]], ")"}], "*", 
    RowBox[{"Exp", "[", 
     RowBox[{"-", 
      FractionBox["h", "ld"]}], "]"}], "*", "convJTokJPerMole"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.919941697227987*^9, 3.9199418106884947`*^9}, {
  3.919942356519916*^9, 3.919942405814177*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"0a9c5177-a6b1-47d1-bc8a-11ba353e4acb"],

